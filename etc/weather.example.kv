# Sample weather source for [weather] source = "@file:..." or a path the daemon
# re-reads per MOTD. An external updater (cron) regenerates this, e.g.:
#   curl -s 'wttr.in/Austin?format=j1' | <jq to these keys> > /var/lib/orochi/weather.kv
location=Austin
country=US
temp_c=22.0
wind_kph=20
precip_mm=0
desc=Partly cloudy
